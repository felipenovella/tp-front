---
// index.astro — página principal del catálogo Boeing
import NavBar from '../components/NavBar.astro';
import AircraftCard from '../components/AircraftCard.astro';
import Modal from '../components/Modal.astro';
import { planes } from '../data/planes.js';
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Catálogo interactivo de aviones comerciales Boeing desde el 707 hasta el 787" />
    <title>Boeing Fleet Catalog</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>

    <!-- ============================
         NAVEGACIÓN
    ============================= -->
    <NavBar />

    <main>

      <!-- ============================
           SECCIÓN 1: HERO
      ============================= -->
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-inner">
          <div class="hero-label">▶ BOEING COMMERCIAL AIRCRAFT · 1958–PRESENTE</div>
          <h1 id="hero-title">
            FLEET <span class="accent">CATALOG</span>
          </h1>
          <p class="hero-sub">
            Catálogo completo de los aviones comerciales Boeing desde el icónico 707
            que inauguró la era del jet, hasta el revolucionario 787 Dreamliner de fibra de carbono.
          </p>
          <div class="hero-stats">
            <div class="hero-stat">
              <span class="stat-num">{planes.length}</span>
              <span class="stat-label">MODELOS</span>
            </div>
            <div class="hero-stat">
              <span class="stat-num">{planes.filter(p => p.status === 'active').length}</span>
              <span class="stat-label">EN SERVICIO</span>
            </div>
            <div class="hero-stat">
              <span class="stat-num">65+</span>
              <span class="stat-label">AÑOS DE HISTORIA</span>
            </div>
          </div>
          <a href="#catalogo" class="hero-cta">Ver catálogo ↓</a>
        </div>
        <div class="hero-bg" aria-hidden="true"></div>
      </section>

      <!-- ============================
           SECCIÓN 2: CATÁLOGO
      ============================= -->
      <section id="catalogo" aria-labelledby="catalogo-title">

        <!-- Controles: filtros y buscador -->
        <div class="controls">
          <div class="filters" role="group" aria-label="Filtrar por era">
            <span class="filter-label">ERA //</span>
            <button class="filter-btn active" data-filter="all">TODOS</button>
            <button class="filter-btn" data-filter="classic">CLÁSICOS</button>
            <button class="filter-btn" data-filter="modern">MODERNOS</button>
            <button class="filter-btn" data-filter="widebody">WIDEBODY</button>
          </div>
          <div class="search-wrap">
            <label for="search" class="sr-only">Buscar modelo</label>
            <span class="search-icon" aria-hidden="true">⌕</span>
            <input
              type="search"
              id="search"
              class="search-input"
              placeholder="BUSCAR MODELO..."
              autocomplete="off"
            />
          </div>
        </div>

        <!-- Barra de conteo -->
        <div class="count-bar" aria-live="polite">
          MOSTRANDO <span id="showing">{planes.length}</span> DE {planes.length} AERONAVES
        </div>

        <!-- Grid de cards -->
        <div class="cards-grid" id="grid" role="list">
          {planes.map((plane, i) => (
            <div
              role="listitem"
              class="card-wrapper fade-in"
              style={`animation-delay: ${i * 0.05}s`}
              data-era={plane.era}
              data-model={plane.model.toLowerCase()}
              data-id={plane.id}
            >
              <AircraftCard plane={plane} />
            </div>
          ))}
        </div>

        <!-- Estado vacío -->
        <div class="empty-state" id="empty" hidden>
          <span>[ SIN RESULTADOS PARA ESA BÚSQUEDA ]</span>
        </div>

      </section>

      <!-- ============================
           SECCIÓN 3: ESTADÍSTICAS
      ============================= -->
      <section id="estadisticas" class="stats-section" aria-labelledby="stats-title">
        <div class="section-inner">
          <h2 id="stats-title" class="section-title">
            DATOS DE LA <span class="accent">FLOTA</span>
          </h2>

          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-card-num accent">
                {planes.filter(p => p.era === 'classic').length}
              </div>
              <div class="stat-card-label">MODELOS CLÁSICOS</div>
              <div class="stat-card-desc">707, 727, 737CL, 747SP, 757</div>
            </div>
            <div class="stat-card">
              <div class="stat-card-num" style="color: #a98be8">
                {planes.filter(p => p.era === 'widebody').length}
              </div>
              <div class="stat-card-label">WIDEBODY</div>
              <div class="stat-card-desc">747, 767, 777 y variantes</div>
            </div>
            <div class="stat-card">
              <div class="stat-card-num" style="color: var(--color-accent2)">
                {planes.filter(p => p.era === 'modern').length}
              </div>
              <div class="stat-card-label">MODERNOS</div>
              <div class="stat-card-desc">717, 737 MAX, 787 Dreamliner</div>
            </div>
            <div class="stat-card">
              <div class="stat-card-num" style="color: #22c55e">
                {planes.filter(p => p.status === 'active').length}
              </div>
              <div class="stat-card-label">EN SERVICIO HOY</div>
              <div class="stat-card-desc">Modelos actualmente operativos</div>
            </div>
          </div>

          <!-- Línea de tiempo -->
          <div class="timeline" aria-label="Línea de tiempo de modelos Boeing">
            <h3 class="timeline-title">LÍNEA DE TIEMPO</h3>
            <div class="timeline-track">
              {planes
                .slice()
                .sort((a, b) => a.debut - b.debut)
                .map((plane) => (
                  <div class="timeline-item" title={`${plane.model} — ${plane.debut}`}>
                    <div class={`timeline-dot era-dot-${plane.era}`}></div>
                    <span class="timeline-year">{plane.debut}</span>
                    <span class="timeline-model">{plane.model}</span>
                  </div>
              ))}
            </div>
            <div class="timeline-legend">
              <span><span class="legend-dot era-dot-classic"></span>Clásico</span>
              <span><span class="legend-dot era-dot-widebody"></span>Widebody</span>
              <span><span class="legend-dot era-dot-modern"></span>Moderno</span>
            </div>
          </div>
        </div>
      </section>

      <!-- ============================
           SECCIÓN 4: SOBRE EL PROYECTO
      ============================= -->
      <section id="sobre" class="about-section" aria-labelledby="about-title">
        <div class="section-inner">
          <h2 id="about-title" class="section-title">
            SOBRE EL <span class="accent">PROYECTO</span>
          </h2>
          <div class="about-grid">
            <div class="about-text">
              <p>
                Este catálogo interactivo cubre los principales modelos de aviones comerciales
                Boeing desde el <strong>707</strong> (1958) hasta el <strong>787 Dreamliner</strong> (2011),
                presentando sus especificaciones técnicas, historia y estado operativo actual.
              </p>
              <p>
                Proyecto desarrollado con <strong>Astro</strong> como trabajo práctico para el
                curso de Frontend. Utiliza componentes reutilizables, HTML semántico,
                CSS Grid, JavaScript vanilla y dark mode.
              </p>
            </div>
            <div class="about-stack">
              <h3 class="about-stack-title">STACK UTILIZADO</h3>
              <ul class="stack-list">
                <li><span class="stack-dot"></span>Astro — framework</li>
                <li><span class="stack-dot"></span>HTML semántico</li>
                <li><span class="stack-dot"></span>CSS Grid + Flexbox</li>
                <li><span class="stack-dot"></span>JavaScript — DOM, eventos</li>
                <li><span class="stack-dot"></span>Google Fonts — Rajdhani, Share Tech Mono</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

    </main>

    <!-- Footer -->
    <footer class="footer">
      <div class="footer-inner">
        <span class="footer-brand">BOEING<span class="accent">FLEET</span> CATALOG</span>
        <span class="footer-credit">
          Trabajo Práctico · Frontend · {new Date().getFullYear()}
        </span>
      </div>
    </footer>

    <!-- Modal (componente reutilizable) -->
    <Modal />

  </body>
</html>

<!-- ============================
     JAVASCRIPT
============================= -->
<script>
  // ── Datos de los aviones (copiados para JS client-side) ──
  // En Astro, los datos del servidor no están disponibles en el script
  // del cliente directamente, así que los embebemos como JSON.
  const PLANES_DATA = document.querySelectorAll('.card-wrapper');

  // ── Datos completos para el modal ──
  const PLANES = [
    { id:"B707",   model:"707",    full:"Boeing 707-320C Intercontinental",        era:"classic",  debut:1958, status:"retired",  pax:"189",  range:"9,265 km",  speed:"1,010 km/h", engines:"4× Pratt & Whitney TF33",       wingspan:"44.4 m", length:"46.6 m", ceiling:"11,887 m", desc:"El primer avión comercial a reacción de Boeing marcó el inicio de la era del jet en la aviación civil. Revolucionó los viajes intercontinentales y estableció a Boeing como líder mundial. Operado por más de 100 aerolíneas, voló por primera vez el 15 de julio de 1954." },
    { id:"B717",   model:"717",    full:"Boeing 717-200",                           era:"classic",   debut:1999, status:"active",   pax:"134",  range:"2,645 km",  speed:"811 km/h",   engines:"2× Rolls-Royce BR715",           wingspan:"28.4 m", length:"37.8 m", ceiling:"11,278 m", desc:"Originalmente el McDonnell Douglas MD-95, fue renombrado 717 tras la fusión con McDonnell Douglas en 1997. Diseñado para rutas cortas y regionales, es altamente eficiente en aeropuertos secundarios." },
    { id:"B727",   model:"727",    full:"Boeing 727-200 Advanced",                 era:"classic",  debut:1963, status:"retired",  pax:"189",  range:"4,020 km",  speed:"960 km/h",   engines:"3× Pratt & Whitney JT8D",        wingspan:"32.9 m", length:"46.7 m", ceiling:"10,670 m", desc:"El trimotor más vendido de Boeing durante su época. Reconocible por sus tres motores en la cola y el ala en flecha pronunciada, fue el caballo de batalla de las aerolíneas en rutas domésticas norteamericanas durante más de dos décadas." },
    { id:"B737",   model:"737",    full:"Boeing 737 MAX 10",                        era:"modern",   debut:1968, status:"active",   pax:"230",  range:"6,110 km",  speed:"839 km/h",   engines:"2× CFM LEAP-1B",                 wingspan:"35.9 m", length:"43.8 m", ceiling:"12,497 m", desc:"La familia más vendida en la historia de la aviación comercial, con más de 10,000 unidades entregadas. Desde el original 737-100 de 1968 hasta el MAX actual, este avión ha transportado más pasajeros que cualquier otro modelo en la historia." },
    { id:"B747",   model:"747",    full:"Boeing 747-8 Intercontinental",            era:"widebody", debut:1969, status:"active",   pax:"467",  range:"14,816 km", speed:"988 km/h",   engines:"4× General Electric GEnx-2B",    wingspan:"68.4 m", length:"76.3 m", ceiling:"13,100 m", desc:"La reina de los cielos. El primer jumbo jet del mundo transformó el transporte masivo de pasajeros y democratizó los viajes internacionales. Su icónica joroba superior es reconocida en todo el mundo." },
    { id:"B747SP", model:"747SP",  full:"Boeing 747SP Special Performance",         era:"widebody", debut:1976, status:"retired",  pax:"331",  range:"15,400 km", speed:"1,000 km/h", engines:"4× Pratt & Whitney JT9D",        wingspan:"59.6 m", length:"56.3 m", ceiling:"13,700 m", desc:"Versión acortada y de ultra-largo alcance del 747, diseñada para rutas de baja demanda pero gran distancia. Fue el primer avión comercial en operar rutas sin escalas como Nueva York-Tokio. Solo se construyeron 45 unidades." },
    { id:"B757",   model:"757",    full:"Boeing 757-300",                           era:"classic",  debut:1982, status:"retired",  pax:"243",  range:"7,270 km",  speed:"850 km/h",   engines:"2× Rolls-Royce RB211-535",       wingspan:"38.1 m", length:"54.5 m", ceiling:"12,802 m", desc:"El único narrowbody de fuselaje largo de Boeing. Famoso por su increíble rendimiento en pistas cortas y altitudes elevadas, fue el favorito para rutas transatlánticas por su eficiencia." },
    { id:"B767",   model:"767",    full:"Boeing 767-400ER",                         era:"widebody", debut:1982, status:"active",   pax:"304",  range:"10,415 km", speed:"851 km/h",   engines:"2× General Electric CF6-80",     wingspan:"51.9 m", length:"61.4 m", ceiling:"13,100 m", desc:"El primer avión de pasillo doble adoptado masivamente en rutas transoceánicas. Pionero en el uso de materiales compuestos y tecnología ETOPS, permitiendo vuelos de larga distancia con solo dos motores." },
    { id:"B777",   model:"777",    full:"Boeing 777X-9",                            era:"widebody", debut:1994, status:"active",   pax:"426",  range:"13,500 km", speed:"905 km/h",   engines:"2× General Electric GE9X-105B1A",wingspan:"71.8 m", length:"76.7 m", ceiling:"13,100 m", desc:"El bimotor comercial más grande del mundo. Primer avión diseñado completamente en CAD 3D digital, el 777 redefinió el vuelo de largo alcance. El 777X introduce alas plegables — una innovación única en la historia de la aviación comercial." },
    { id:"B787",   model:"787",    full:"Boeing 787-10 Dreamliner",                 era:"modern",   debut:2011, status:"active",   pax:"330",  range:"11,910 km", speed:"903 km/h",   engines:"2× General Electric GEnx-1B",    wingspan:"60.1 m", length:"68.3 m", ceiling:"13,100 m", desc:"El Dreamliner revolucionó la fabricación aeronáutica con un fuselaje 50% compuesto de fibra de carbono. Mayor presión de cabina, ventanas electrocrómicas más grandes y mejor humedad interior." },
    { id:"B737CL", model:"737CL",  full:"Boeing 737 Classic (-300/-400/-500)",      era:"classic",  debut:1984, status:"retired",  pax:"149",  range:"5,084 km",  speed:"810 km/h",   engines:"2× CFM International CFM56-3",   wingspan:"28.9 m", length:"36.5 m", ceiling:"11,300 m", desc:"La segunda generación del 737 introdujo los motores CFM56 y modernizó completamente la cabina con aviónica digital. Base del éxito masivo de la familia 737, con más de 1,988 unidades vendidas." },
    { id:"B747F",  model:"747F",   full:"Boeing 747-8 Freighter",                   era:"widebody", debut:2010, status:"active",   pax:"—",    range:"8,130 km",  speed:"988 km/h",   engines:"4× General Electric GEnx-2B67",  wingspan:"68.4 m", length:"76.3 m", ceiling:"13,100 m", desc:"La versión carguera del 747-8 y el mayor avión de carga comercial de Boeing. Con capacidad para 140 toneladas métricas, domina las rutas de carga intercontinentales. Operado por UPS, FedEx y Lufthansa Cargo." },
  ];

  // ── Estado de filtros ──
  let activeFilter = 'all';
  let searchQuery = '';

  // ── Referencias al DOM ──
  const grid       = document.getElementById('grid');
  const showing    = document.getElementById('showing');
  const empty      = document.getElementById('empty');
  const searchEl   = document.getElementById('search');
  const modal      = document.getElementById('modal');
  const modalClose = document.getElementById('modal-close');
  const filterBtns = document.querySelectorAll('.filter-btn');

  // ── Función principal de filtrado ──
  function applyFilters() {
    let count = 0;

    document.querySelectorAll('.card-wrapper').forEach(wrapper => {
      const era   = wrapper.dataset.era;
      const model = wrapper.dataset.model;
      const id    = wrapper.dataset.id?.toLowerCase() ?? '';

      const matchFilter = activeFilter === 'all' || era === activeFilter;
      const q = searchQuery.toLowerCase();
      const matchSearch = !q || model.includes(q) || id.includes(q);

      if (matchFilter && matchSearch) {
        wrapper.hidden = false;
        count++;
      } else {
        wrapper.hidden = true;
      }
    });

    showing.textContent = count;
    empty.hidden = count > 0;
  }

  // ── Filtros por ERA ──
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeFilter = btn.dataset.filter;
      applyFilters();
    });
  });

  // ── Buscador en tiempo real ──
  searchEl.addEventListener('input', (e) => {
    searchQuery = e.target.value;
    applyFilters();
  });

  // ── Abrir modal al hacer click en una card ──
  grid.addEventListener('click', (e) => {
    const wrapper = e.target.closest('.card-wrapper');
    if (!wrapper) return;
    openModal(wrapper.dataset.id);
  });

  // También con teclado (accesibilidad)
  grid.addEventListener('keydown', (e) => {
    if (e.key !== 'Enter' && e.key !== ' ') return;
    const wrapper = e.target.closest('.card-wrapper');
    if (!wrapper) return;
    e.preventDefault();
    openModal(wrapper.dataset.id);
  });

  // ── Función para abrir el modal con datos del avión ──
  function openModal(id) {
    const plane = PLANES.find(p => p.id === id);
    if (!plane) return;

    document.getElementById('modal-id').textContent   = 'BOE-' + plane.id;
    document.getElementById('modal-title').textContent = plane.model;
    document.getElementById('modal-full').textContent  = plane.full;
    document.getElementById('modal-desc').textContent  = plane.desc;

    const specsEl = document.getElementById('modal-specs');
    specsEl.innerHTML = [
      ['PASAJEROS',   plane.pax],
      ['ALCANCE',     plane.range],
      ['VELOCIDAD',   plane.speed],
      ['ENVERGADURA', plane.wingspan],
      ['LONGITUD',    plane.length],
      ['TECHO MÁX.',  plane.ceiling],
    ].map(([label, val]) => `
      <div class="modal-spec">
        <dt>${label}</dt>
        <dd>${val}</dd>
      </div>
    `).join('');

    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    modalClose.focus();
  }

  // ── Cerrar modal ──
  function closeModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
  }

  modalClose.addEventListener('click', closeModal);

  modal.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });

  // ── Dark mode toggle ──
  const darkToggle = document.getElementById('darkToggle');
  const toggleIcon = document.getElementById('toggleIcon');

  // Recuperar preferencia guardada
  const savedTheme = localStorage.getItem('theme');
  if (savedTheme === 'light') {
    document.documentElement.setAttribute('data-theme', 'light');
    toggleIcon.textContent = '☾';
  }

  darkToggle.addEventListener('click', () => {
    const isLight = document.documentElement.getAttribute('data-theme') === 'light';
    if (isLight) {
      document.documentElement.removeAttribute('data-theme');
      toggleIcon.textContent = '☀';
      localStorage.setItem('theme', 'dark');
    } else {
      document.documentElement.setAttribute('data-theme', 'light');
      toggleIcon.textContent = '☾';
      localStorage.setItem('theme', 'light');
    }
  });
</script>

<style>
  /* ============================
     HERO
  ============================= */
  .hero {
    position: relative;
    padding: 72px 32px 56px;
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      90deg,
      transparent,
      transparent 39px,
      var(--color-border) 39px,
      var(--color-border) 40px
    );
    pointer-events: none;
    opacity: 0.4;
    z-index: 0;
  }

  .hero-inner {
    position: relative;
    z-index: 1;
    max-width: 700px;
  }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-accent2);
    letter-spacing: 3px;
    margin-bottom: 12px;
  }

  .hero h1 {
    font-size: clamp(48px, 8vw, 80px);
    font-weight: 700;
    letter-spacing: -2px;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  .accent { color: var(--color-accent); }

  .hero-sub {
    font-size: 16px;
    font-weight: 300;
    color: var(--color-muted);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .hero-stats {
    display: flex;
    gap: 40px;
    margin-bottom: 36px;
  }

  .hero-stat {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .stat-num {
    font-family: var(--font-head);
    font-size: 36px;
    font-weight: 700;
    color: var(--color-dim);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-muted);
    letter-spacing: 1.5px;
  }

  .hero-cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2px;
    padding: 10px 24px;
    border: 1px solid var(--color-accent);
    color: var(--color-accent2);
    border-radius: 2px;
    transition: all 0.15s;
  }
  .hero-cta:hover {
    background: var(--color-accent);
    color: #fff;
    text-decoration: none;
  }

  /* ============================
     CONTROLES (filtros + búsqueda)
  ============================= */
  .controls {
    padding: 14px 24px;
    display: flex;
    gap: 8px;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-muted);
    letter-spacing: 2px;
    margin-right: 4px;
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 5px 12px;
    border: 1px solid var(--color-border2);
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    border-radius: 2px;
    letter-spacing: 1px;
    transition: all 0.15s;
  }
  .filter-btn:hover { border-color: var(--color-accent); color: var(--color-accent2); }
  .filter-btn.active { background: var(--color-accent); border-color: var(--color-accent); color: #fff; }

  .search-wrap {
    margin-left: auto;
    position: relative;
  }

  .search-input {
    background: var(--color-surface);
    border: 1px solid var(--color-border2);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 6px 12px 6px 32px;
    border-radius: 2px;
    width: 200px;
    outline: none;
    transition: border-color 0.15s;
  }
  .search-input:focus { border-color: var(--color-accent); }
  .search-input::placeholder { color: var(--color-dim); }

  .search-icon {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--color-dim);
    font-size: 14px;
    pointer-events: none;
  }

  /* Barra de conteo */
  .count-bar {
    padding: 8px 24px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-dim);
    letter-spacing: 1px;
    border-bottom: 1px solid var(--color-border);
  }
  .count-bar span { color: var(--color-accent2); }

  /* ============================
     GRID DE CARDS
  ============================= */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    gap: 0;
    background: var(--color-border);
