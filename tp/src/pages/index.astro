---
// Importo los componentes y los datos
import NavBar from '../components/NavBar.astro';
import AircraftCard from '../components/AircraftCard.astro';
import Modal from '../components/Modal.astro';
import { planes } from '../data/planes.js';
import '../styles/global.css';
---

<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Boeing Fleet Catalog</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>

  <body>

    <NavBar />

    <main>

      <!-- Sección 1: Hero -->
      <section class="hero">
        <div class="hero-inner">
          <p class="hero-label">BOEING COMMERCIAL AIRCRAFT · 1958–PRESENTE</p>
          <h1>FLEET <span class="accent">CATALOG</span></h1>
          <p class="hero-sub">
            Catálogo de aviones comerciales Boeing desde el 707 hasta el 787 Dreamliner.
          </p>
          <div class="hero-stats">
            <div class="hero-stat">
              <span class="stat-num">{planes.length}</span>
              <span class="stat-label">MODELOS</span>
            </div>
            <div class="hero-stat">
              <span class="stat-num">{planes.filter(p => p.status === 'active').length}</span>
              <span class="stat-label">EN SERVICIO</span>
            </div>
            <div class="hero-stat">
              <span class="stat-num">65+</span>
              <span class="stat-label">AÑOS DE HISTORIA</span>
            </div>
          </div>
          <a href="#catalogo" class="hero-cta">Ver catálogo ↓</a>
        </div>
      </section>

      <!-- Sección 2: Catálogo -->
      <section id="catalogo">

        <!-- Filtros y buscador -->
        <div class="controls">
          <div class="filters">
            <span class="filter-label">FILTRAR:</span>
            <button class="filter-btn active" data-filter="all">TODOS</button>
            <button class="filter-btn" data-filter="classic">CLÁSICOS</button>
            <button class="filter-btn" data-filter="modern">MODERNOS</button>
            <button class="filter-btn" data-filter="widebody">WIDEBODY</button>
          </div>
          <div class="search-wrap">
            <input
              type="search"
              id="search"
              class="search-input"
              placeholder="Buscar modelo..."
              autocomplete="off"
            />
          </div>
        </div>

        <div class="count-bar">
          Mostrando <span id="showing">{planes.length}</span> de {planes.length} aviones
        </div>

        <!-- Grid de cards -->
        <div class="cards-grid" id="grid">
          {planes.map((plane) => (
            <div
              class="card-wrapper"
              data-era={plane.era}
              data-model={plane.model.toLowerCase()}
              data-id={plane.id}
            >
              <AircraftCard plane={plane} />
            </div>
          ))}
        </div>

        <div class="empty-state" id="empty" hidden>
          No se encontraron resultados.
        </div>

      </section>

      <!-- Sección 3: Estadísticas -->
      <section id="estadisticas" class="stats-section">
        <div class="section-inner">
          <h2 class="section-title">DATOS DE LA <span class="accent">FLOTA</span></h2>

          <div class="stats-grid">
            <div class="stat-card">
              <div class="stat-num accent">{planes.filter(p => p.era === 'classic').length}</div>
              <div class="stat-card-label">CLÁSICOS</div>
            </div>
            <div class="stat-card">
              <div class="stat-num" style="color: #a98be8">{planes.filter(p => p.era === 'widebody').length}</div>
              <div class="stat-card-label">WIDEBODY</div>
            </div>
            <div class="stat-card">
              <div class="stat-num" style="color: var(--color-accent2)">{planes.filter(p => p.era === 'modern').length}</div>
              <div class="stat-card-label">MODERNOS</div>
            </div>
            <div class="stat-card">
              <div class="stat-num" style="color: #22c55e">{planes.filter(p => p.status === 'active').length}</div>
              <div class="stat-card-label">EN SERVICIO HOY</div>
            </div>
          </div>

          <!-- Línea de tiempo -->
          <div class="timeline">
            <h3 class="timeline-title">LÍNEA DE TIEMPO</h3>
            <div class="timeline-track">
              {planes
                .slice()
                .sort((a, b) => a.debut - b.debut)
                .map((plane) => (
                  <div class="timeline-item">
                    <div class={`timeline-dot era-dot-${plane.era}`}></div>
                    <span class="timeline-year">{plane.debut}</span>
                    <span class="timeline-model">{plane.model}</span>
                  </div>
              ))}
            </div>
            <div class="timeline-legend">
              <span><span class="legend-dot era-dot-classic"></span>Clásico</span>
              <span><span class="legend-dot era-dot-widebody"></span>Widebody</span>
              <span><span class="legend-dot era-dot-modern"></span>Moderno</span>
            </div>
          </div>
        </div>
      </section>

      <!-- Sección 4: Sobre el proyecto -->
      <section id="sobre" class="about-section">
        <div class="section-inner">
          <h2 class="section-title">SOBRE EL <span class="accent">PROYECTO</span></h2>
          <div class="about-grid">
            <div class="about-text">
              <p>
                Este catálogo muestra los aviones comerciales Boeing desde el <strong>707</strong> (1958)
                hasta el <strong>787 Dreamliner</strong> (2011), con sus especificaciones técnicas
                y estado operativo actual.
              </p>
              <p>
                Trabajo práctico desarrollado con <strong>Astro</strong> para el curso de Frontend.
              </p>
            </div>
            <div class="about-stack">
              <h3 class="about-stack-title">HERRAMIENTAS USADAS</h3>
              <ul class="stack-list">
                <li><span class="stack-dot"></span>Astro</li>
                <li><span class="stack-dot"></span>HTML semántico</li>
                <li><span class="stack-dot"></span>CSS Grid + Flexbox</li>
                <li><span class="stack-dot"></span>JavaScript vanilla</li>
                <li><span class="stack-dot"></span>Google Fonts</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

    </main>

    <footer class="footer">
      <div class="footer-inner">
        <span class="footer-brand">BOEING<span class="accent">FLEET</span></span>
        <span class="footer-credit">TP Frontend · Felipe Novella · 5°C · {new Date().getFullYear()}</span>
      </div>
    </footer>

    <Modal />

  </body>
</html>

<script>
  // Datos de los aviones para el modal
  const PLANES = [
    { id:"B707",   model:"707",    full:"Boeing 707-320C Intercontinental",   era:"classic",  debut:1958, status:"retired", pax:"189", range:"9,265 km",  speed:"1,010 km/h", engines:"4× Pratt & Whitney TF33",        wingspan:"44.4 m", length:"46.6 m", ceiling:"11,887 m", desc:"El primer avión comercial a reacción de Boeing. Revolucionó los viajes intercontinentales y marcó el inicio de la era del jet en la aviación civil." },
    { id:"B717",   model:"717",    full:"Boeing 717-200",                      era:"classic",  debut:1999, status:"active",  pax:"134", range:"2,645 km",  speed:"811 km/h",   engines:"2× Rolls-Royce BR715",           wingspan:"28.4 m", length:"37.8 m", ceiling:"11,278 m", desc:"Originalmente el McDonnell Douglas MD-95. Diseñado para rutas cortas y regionales, es muy eficiente en aeropuertos secundarios." },
    { id:"B727",   model:"727",    full:"Boeing 727-200 Advanced",             era:"classic",  debut:1963, status:"retired", pax:"189", range:"4,020 km",  speed:"960 km/h",   engines:"3× Pratt & Whitney JT8D",        wingspan:"32.9 m", length:"46.7 m", ceiling:"10,670 m", desc:"El trimotor más vendido de Boeing. Reconocible por sus tres motores en la cola, fue el caballo de batalla de las aerolíneas durante dos décadas." },
    { id:"B737",   model:"737",    full:"Boeing 737 MAX 10",                   era:"modern",   debut:1968, status:"active",  pax:"230", range:"6,110 km",  speed:"839 km/h",   engines:"2× CFM LEAP-1B",                 wingspan:"35.9 m", length:"43.8 m", ceiling:"12,497 m", desc:"La familia más vendida en la historia de la aviación, con más de 10,000 unidades entregadas. Está en su cuarta generación con el 737 MAX." },
    { id:"B747",   model:"747",    full:"Boeing 747-8 Intercontinental",       era:"widebody", debut:1969, status:"active",  pax:"467", range:"14,816 km", speed:"988 km/h",   engines:"4× General Electric GEnx-2B",    wingspan:"68.4 m", length:"76.3 m", ceiling:"13,100 m", desc:"La reina de los cielos. El primer jumbo jet del mundo, reconocible por su icónica joroba. Democratizó los viajes internacionales al reducir el costo por pasajero." },
    { id:"B757",   model:"757",    full:"Boeing 757-300",                      era:"classic",  debut:1982, status:"retired", pax:"243", range:"7,270 km",  speed:"850 km/h",   engines:"2× Rolls-Royce RB211-535",       wingspan:"38.1 m", length:"54.5 m", ceiling:"12,802 m", desc:"El único narrowbody de fuselaje largo de Boeing. Muy popular en rutas transatlánticas por su eficiencia y buen rendimiento en pistas cortas." },
    { id:"B767",   model:"767",    full:"Boeing 767-400ER",                    era:"widebody", debut:1982, status:"active",  pax:"304", range:"10,415 km", speed:"851 km/h",   engines:"2× General Electric CF6-80",     wingspan:"51.9 m", length:"61.4 m", ceiling:"13,100 m", desc:"El primer widebody adoptado masivamente en rutas transoceánicas. Fue pionero en la tecnología ETOPS, que permite vuelos largos con solo dos motores." },
    { id:"B777",   model:"777",    full:"Boeing 777X-9",                       era:"widebody", debut:1994, status:"active",  pax:"426", range:"13,500 km", speed:"905 km/h",   engines:"2× General Electric GE9X",       wingspan:"71.8 m", length:"76.7 m", ceiling:"13,100 m", desc:"El bimotor comercial más grande del mundo. El 777X introduce alas plegables, una innovación única en la aviación comercial." },
    { id:"B787",   model:"787",    full:"Boeing 787-10 Dreamliner",            era:"modern",   debut:2011, status:"active",  pax:"330", range:"11,910 km", speed:"903 km/h",   engines:"2× General Electric GEnx-1B",    wingspan:"60.1 m", length:"68.3 m", ceiling:"13,100 m", desc:"El Dreamliner usa un 50% de materiales compuestos de fibra de carbono. Tiene ventanas más grandes, mayor presión de cabina y mejor humedad interior." },
    { id:"B747F",  model:"747F",   full:"Boeing 747-8 Freighter",              era:"widebody", debut:2010, status:"active",  pax:"—",   range:"8,130 km",  speed:"988 km/h",   engines:"4× General Electric GEnx-2B67",  wingspan:"68.4 m", length:"76.3 m", ceiling:"13,100 m", desc:"La versión carguera del 747-8. Puede cargar hasta 140 toneladas. Lo usan empresas como UPS, FedEx y Lufthansa Cargo." },
  ];

  // Referencias a los elementos del HTML
  const grid       = document.getElementById('grid')!;
  const showing    = document.getElementById('showing')!;
  const empty      = document.getElementById('empty')!;
  const searchEl   = document.getElementById('search')!;
  const modal      = document.getElementById('modal')!;
  const modalClose = document.getElementById('modal-close')!;
  const filterBtns = document.querySelectorAll('.filter-btn');

  let filtroActivo = 'all';
  let busqueda = '';

  // Función que muestra u oculta las cards según el filtro y la búsqueda
  function filtrar() {
    let cantidad = 0;

    document.querySelectorAll('.card-wrapper').forEach(wrapper => {
      const era   = (wrapper as HTMLElement).dataset.era;
      const model = (wrapper as HTMLElement).dataset.model ?? '';
      const id    = (wrapper as HTMLElement).dataset.id?.toLowerCase() ?? '';

      const coincideFiltro = filtroActivo === 'all' || era === filtroActivo;
      const q = busqueda.toLowerCase();
      const coincideBusqueda = !q || model.includes(q) || id.includes(q);

      if (coincideFiltro && coincideBusqueda) {
        (wrapper as HTMLElement).hidden = false;
        cantidad++;
      } else {
        (wrapper as HTMLElement).hidden = true;
      }
    });

    showing.textContent = String(cantidad);
    (empty as HTMLElement).hidden = cantidad > 0;
  }

  // Eventos de los botones de filtro
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      filtroActivo = (btn as HTMLElement).dataset.filter ?? 'all';
      filtrar();
    });
  });

  // Evento del buscador
  searchEl.addEventListener('input', (e) => {
    busqueda = (e.target as HTMLInputElement).value;
    filtrar();
  });

  // Abrir modal al hacer click en una card
  grid.addEventListener('click', (e) => {
    const wrapper = (e.target as HTMLElement).closest('.card-wrapper');
    if (!wrapper) return;
    abrirModal((wrapper as HTMLElement).dataset.id ?? '');
  });

  // Función para abrir el modal con los datos del avión clickeado
  function abrirModal(id: string) {
    const avion = PLANES.find(p => p.id === id);
    if (!avion) return;

    document.getElementById('modal-id')!.textContent    = 'BOE-' + avion.id;
    document.getElementById('modal-title')!.textContent = avion.model;
    document.getElementById('modal-full')!.textContent  = avion.full;
    document.getElementById('modal-desc')!.textContent  = avion.desc;

    const specsEl = document.getElementById('modal-specs')!;
    specsEl.innerHTML = [
      ['PASAJEROS',   avion.pax],
      ['ALCANCE',     avion.range],
      ['VELOCIDAD',   avion.speed],
      ['ENVERGADURA', avion.wingspan],
      ['LONGITUD',    avion.length],
      ['TECHO MÁX.',  avion.ceiling],
    ].map(([label, val]) => `
      <div class="modal-spec">
        <dt>${label}</dt>
        <dd>${val}</dd>
      </div>
    `).join('');

    modal.hidden = false;
    document.body.style.overflow = 'hidden';
    modalClose.focus();
  }

  // Cerrar modal
  function cerrarModal() {
    modal.hidden = true;
    document.body.style.overflow = '';
  }

  modalClose.addEventListener('click', cerrarModal);
  modal.addEventListener('click', (e) => { if (e.target === modal) cerrarModal(); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') cerrarModal(); });

  // Dark mode
  const darkToggle = document.getElementById('darkToggle')!;
  const toggleIcon = document.getElementById('toggleIcon')!;

  if (localStorage.getItem('theme') === 'light') {
    document.documentElement.setAttribute('data-theme', 'light');
    toggleIcon.textContent = '☾';
  }

  darkToggle.addEventListener('click', () => {
    const esLight = document.documentElement.getAttribute('data-theme') === 'light';
    if (esLight) {
      document.documentElement.removeAttribute('data-theme');
      toggleIcon.textContent = '☀';
      localStorage.setItem('theme', 'dark');
    } else {
      document.documentElement.setAttribute('data-theme', 'light');
      toggleIcon.textContent = '☾';
      localStorage.setItem('theme', 'light');
    }
  });
</script>

<style>
  /* Hero */
  .hero {
    position: relative;
    padding: 72px 32px 56px;
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      90deg,
      transparent, transparent 39px,
      var(--color-border) 39px, var(--color-border) 40px
    );
    opacity: 0.4;
  }

  .hero-inner { position: relative; max-width: 700px; }

  .hero-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-accent2);
    letter-spacing: 3px;
    margin-bottom: 12px;
  }

  .hero h1 {
    font-size: clamp(48px, 8vw, 80px);
    font-weight: 700;
    letter-spacing: -2px;
    color: var(--color-text);
    margin-bottom: 16px;
  }

  .accent { color: var(--color-accent); }

  .hero-sub {
    font-size: 16px;
    font-weight: 300;
    color: var(--color-muted);
    max-width: 520px;
    line-height: 1.7;
    margin-bottom: 32px;
  }

  .hero-stats {
    display: flex;
    gap: 40px;
    margin-bottom: 36px;
  }

  .hero-stat { display: flex; flex-direction: column; gap: 2px; }

  .stat-num {
    font-family: var(--font-head);
    font-size: 36px;
    font-weight: 700;
    color: var(--color-dim);
    line-height: 1;
  }

  .stat-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-muted);
    letter-spacing: 1.5px;
  }

  .hero-cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: 2px;
    padding: 10px 24px;
    border: 1px solid var(--color-accent);
    color: var(--color-accent2);
    border-radius: 2px;
    transition: all 0.15s;
  }
  .hero-cta:hover { background: var(--color-accent); color: #fff; text-decoration: none; }

  /* Filtros */
  .controls {
    padding: 14px 24px;
    display: flex;
    gap: 8px;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    flex-wrap: wrap;
  }

  .filter-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-muted);
    letter-spacing: 2px;
  }

  .filter-btn {
    font-family: var(--font-mono);
    font-size: 11px;
    padding: 5px 12px;
    border: 1px solid var(--color-border2);
    background: transparent;
    color: var(--color-muted);
    cursor: pointer;
    border-radius: 2px;
    letter-spacing: 1px;
    transition: all 0.15s;
  }
  .filter-btn:hover { border-color: var(--color-accent); color: var(--color-accent2); }
  .filter-btn.active { background: var(--color-accent); border-color: var(--color-accent); color: #fff; }

  .search-wrap { margin-left: auto; }

  .search-input {
    background: var(--color-surface);
    border: 1px solid var(--color-border2);
    color: var(--color-text);
    font-family: var(--font-mono);
    font-size: 12px;
    padding: 6px 12px;
    border-radius: 2px;
    width: 200px;
    outline: none;
    transition: border-color 0.15s;
  }
  .search-input:focus { border-color: var(--color-accent); }
  .search-input::placeholder { color: var(--color-dim); }

  .count-bar {
    padding: 8px 24px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-dim);
    letter-spacing: 1px;
    border-bottom: 1px solid var(--color-border);
  }
  .count-bar span { color: var(--color-accent2); }

  /* Grid */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(290px, 1fr));
    background: var(--color-border);
    gap: 1px;
  }

  .card-wrapper { background: var(--color-bg); }

  .empty-state {
    padding: 60px;
    text-align: center;
    font-family: var(--font-mono);
    color: var(--color-dim);
    font-size: 13px;
  }

  /* Estadísticas */
  .stats-section {
    border-top: 1px solid var(--color-border);
    padding: 64px 0;
    background: var(--color-surface);
  }

  .section-inner { max-width: 1200px; margin: 0 auto; padding: 0 24px; }

  .section-title {
    font-family: var(--font-head);
    font-size: 36px;
    font-weight: 700;
    letter-spacing: -1px;
    margin-bottom: 40px;
    color: var(--color-text);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1px;
    background: var(--color-border);
    margin-bottom: 48px;
  }

  .stat-card { background: var(--color-surface2); padding: 28px 24px; }

  .stat-card-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-muted);
    letter-spacing: 2px;
    margin-top: 6px;
  }

  /* Timeline */
  .timeline { border-top: 1px solid var(--color-border); padding-top: 32px; }

  .timeline-title {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-muted);
    letter-spacing: 2px;
    margin-bottom: 20px;
  }

  .timeline-track {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    border-left: 2px solid var(--color-border2);
    padding-left: 20px;
  }

  .timeline-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    position: relative;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: -24px;
    top: 6px;
    width: 10px;
    height: 1px;
    background: var(--color-border2);
  }

  .timeline-dot { width: 10px; height: 10px; border-radius: 50%; }
  .era-dot-classic  { background: var(--color-gold); }
  .era-dot-modern   { background: var(--color-accent2); }
  .era-dot-widebody { background: #a98be8; }

  .timeline-year { font-family: var(--font-mono); font-size: 10px; color: var(--color-muted); }
  .timeline-model { font-family: var(--font-head); font-size: 13px; font-weight: 600; color: var(--color-text); }

  .timeline-legend {
    display: flex;
    gap: 20px;
    margin-top: 20px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-muted);
  }

  .legend-dot {
    display: inline-block;
    width: 8px; height: 8px;
    border-radius: 50%;
    margin-right: 5px;
  }

  /* Sobre */
  .about-section { border-top: 1px solid var(--color-border); padding: 64px 0; }

  .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; }

  .about-text p {
    font-size: 15px;
    font-weight: 300;
    color: var(--color-muted);
    line-height: 1.8;
    margin-bottom: 16px;
  }
  .about-text strong { color: var(--color-text); font-weight: 500; }

  .about-stack-title {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-muted);
    letter-spacing: 2px;
    margin-bottom: 16px;
  }

  .stack-list { list-style: none; display: flex; flex-direction: column; gap: 10px; }

  .stack-list li {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--color-text);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .stack-dot {
    width: 6px; height: 6px;
    background: var(--color-accent);
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Footer */
  .footer { border-top: 1px solid var(--color-border); padding: 20px 0; background: var(--color-surface); }

  .footer-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .footer-brand { font-family: var(--font-head); font-size: 16px; font-weight: 700; color: var(--color-text); }
